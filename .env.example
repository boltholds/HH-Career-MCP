# HH.ru application OAuth
HH_CLIENT_ID=
HH_CLIENT_SECRET=
HH_REDIRECT_URI=http://127.0.0.1:8766/oauth/callback
HH_TOKEN_FILE=.data/hh/token.json

# Optional manual token override. Leave empty for the managed OAuth flow.
HH_ACCESS_TOKEN=

# HH API client
HH_USER_AGENT=HH-Career-MCP/0.2 (your-email@example.com)
HH_API_BASE_URL=https://api.hh.ru
HH_REQUEST_TIMEOUT_SECONDS=20

# Local MCP defaults. Docker Compose overrides these for Streamable HTTP.
HH_MCP_TRANSPORT=stdio
HH_MCP_HOST=127.0.0.1
HH_MCP_PORT=8000
HH_MCP_PATH=/mcp
HH_MCP_PORT_FORWARD=8000
HH_OAUTH_CALLBACK_PORT=8766

# OpenAI Secure MCP Tunnel
TUNNEL_ID=tunnel_replace_me
CONTROL_PLANE_API_KEY=
TUNNEL_PROFILE=hh-career-mcp
TUNNEL_HEALTH_PORT=8082
TUNNEL_CLIENT_VERSION=0.0.10
